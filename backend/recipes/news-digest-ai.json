{
  "id": "news-digest-ai",
  "title": "News digest AI",
  "description": "Genera un resumen personalizado de noticias a partir de los temas que te interesan y el idioma que prefieras.",
  "category": "life",
  "icon": "newspaper",
  "estimatedTime": "7s",
  "integrations": ["RSS", "AI"],
  "popular": true,
  "n8nWebhookPath": "/webhook/news-digest-ai",
  "fields": [
    {
      "id": "topics",
      "label": "Temas que quieres seguir",
      "type": "textarea",
      "placeholder": "IA, startups europeas, productividad, ciberseguridad...",
      "required": true
    },
    {
      "id": "language",
      "label": "Idioma del resumen",
      "type": "select",
      "options": ["Español", "English"],
      "required": true
    },
    {
      "id": "email",
      "label": "Email de entrega",
      "type": "email",
      "placeholder": "tu@email.com",
      "required": true
    }
  ],
  "resultTemplate": {
    "type": "text",
    "features": ["copy-text", "share"]
  }
}
