{
  "id": "review-responder",
  "title": "Review responder",
  "description": "Genera una respuesta lista para copiar a una reseña con el tono de tu negocio.",
  "category": "biz",
  "icon": "message-square-heart",
  "estimatedTime": "6s",
  "integrations": ["AI"],
  "popular": true,
  "n8nWebhookPath": "/webhook/review-responder",
  "fields": [
    {
      "id": "businessName",
      "label": "Nombre del negocio",
      "type": "text",
      "placeholder": "Cafe Aurora",
      "required": true
    },
    {
      "id": "tone",
      "label": "Tono de la respuesta",
      "type": "select",
      "options": ["Profesional", "Cercano", "Empatico", "Firme"],
      "required": true
    },
    {
      "id": "reviewText",
      "label": "Texto de la reseña",
      "type": "textarea",
      "placeholder": "El cafe estaba bueno pero el servicio fue muy lento...",
      "required": true
    }
  ],
  "resultTemplate": {
    "type": "text",
    "features": ["copy-text", "regenerate"]
  }
}
