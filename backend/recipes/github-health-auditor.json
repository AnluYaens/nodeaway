{
  "id": "github-health-auditor",
  "title": "Auditor de Salud de GitHub",
  "description": "Analiza la deuda técnica, actividad y salud general de un repositorio público.",
  "category": "dev",
  "icon": "github",
  "estimatedTime": "10s",
  "integrations": ["GitHub"],
  "popular": false,
  "n8nWebhookPath": "/webhook/github-health-auditor",
  "fields": [
    {
      "id": "repo",
      "label": "URL del repositorio",
      "type": "text",
      "placeholder": "https://github.com/owner/repo",
      "required": true
    },
    {
      "id": "token",
      "label": "GitHub Token (opcional, solo repos privados)",
      "type": "password",
      "required": false
    }
  ],
  "resultTemplate": {
    "type": "dashboard",
    "features": ["health-metrics", "technical-debt", "priority-list"]
  }
}
