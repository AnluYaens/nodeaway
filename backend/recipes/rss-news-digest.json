{
  "id": "rss-news-digest",
  "title": "Boletín de Noticias RSS",
  "description": "Busca las noticias de las últimas 24h sobre un tema y redacta un resumen matutino listo para leer.",
  "category": "life",
  "icon": "rss",
  "estimatedTime": "7s",
  "integrations": ["RSS"],
  "popular": true,
  "n8nWebhookPath": "/webhook/rss-news-digest",
  "fields": [
    {
      "id": "topics",
      "label": "Temas de interés",
      "type": "text",
      "placeholder": "IA, Economía, Startups...",
      "required": true
    },
    {
      "id": "language",
      "label": "Idioma",
      "type": "select",
      "options": ["Español", "English", "Deutsch", "Français"],
      "required": true
    }
  ],
  "resultTemplate": {
    "type": "text",
    "features": ["headlines", "briefing", "actionable-summary"]
  }
}
