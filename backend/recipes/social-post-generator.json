{
  "id": "social-post-generator",
  "title": "Social post generator",
  "description": "Genera posts para redes sociales con texto e imagen AI adaptados a tu marca.",
  "category": "biz",
  "icon": "sparkles",
  "estimatedTime": "8s",
  "integrations": ["AI", "Gemini Image"],
  "popular": true,
  "n8nWebhookPath": "/webhook/social-post-generator",
  "fields": [
    {
      "id": "brand",
      "label": "Describe tu marca",
      "type": "textarea",
      "placeholder": "Cafeteria artesanal en Madrid con enfoque sostenible...",
      "required": true
    },
    {
      "id": "platform",
      "label": "Plataforma",
      "type": "select",
      "options": ["Instagram", "Twitter/X", "LinkedIn", "Todas"],
      "required": true
    },
    {
      "id": "tone",
      "label": "Tono",
      "type": "select",
      "options": ["Profesional", "Casual", "Divertido", "Inspirador"],
      "required": true
    },
    {
      "id": "count",
      "label": "Cantidad de posts",
      "type": "number",
      "placeholder": "5",
      "required": false,
      "min": 1,
      "max": 10,
      "default": 5
    }
  ],
  "resultTemplate": {
    "type": "social-posts",
    "features": ["copy-text", "download-image", "download-zip", "regenerate"]
  }
}
