{
  "id": "price-watcher",
  "title": "Price watcher",
  "description": "Revisa el precio actual de un producto, lo compara con tu objetivo y deja el analisis listo.",
  "category": "life",
  "icon": "badge-dollar-sign",
  "estimatedTime": "9s",
  "integrations": ["Web scraping", "AI"],
  "popular": false,
  "n8nWebhookPath": "/webhook/price-watcher",
  "fields": [
    {
      "id": "productUrl",
      "label": "URL del producto",
      "type": "url",
      "placeholder": "https://tienda.com/producto",
      "required": true
    },
    {
      "id": "targetPrice",
      "label": "Precio objetivo",
      "type": "number",
      "placeholder": "99",
      "required": true
    },
    {
      "id": "email",
      "label": "Email para recibir alertas",
      "type": "email",
      "placeholder": "tu@email.com",
      "required": true
    }
  ],
  "resultTemplate": {
    "type": "report",
    "features": ["price-analysis", "insights", "recommendations"]
  }
}
