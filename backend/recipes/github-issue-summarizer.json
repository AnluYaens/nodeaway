{
  "id": "github-issue-summarizer",
  "title": "Resumidor de Issues de GitHub",
  "description": "Descarga los últimos issues de un repositorio y los categoriza por urgencia.",
  "category": "dev",
  "icon": "github",
  "estimatedTime": "12s",
  "integrations": ["GitHub"],
  "popular": true,
  "n8nWebhookPath": "/webhook/github-issue-summarizer",
  "fields": [
    {
      "id": "repo",
      "label": "URL del repositorio",
      "type": "text",
      "placeholder": "https://github.com/owner/repo",
      "required": true
    },
    {
      "id": "token",
      "label": "GitHub Token (opcional, solo repos privados)",
      "type": "password",
      "required": false
    }
  ],
  "resultTemplate": {
    "type": "dashboard",
    "features": ["triage", "priority-list", "metrics"]
  }
}
